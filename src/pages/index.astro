---
import SiteLayout from '../layouts/SiteLayout.astro';
import AcademicSection from '../components/academic/AcademicSection.astro';
import NewsTimeline from '../components/academic/NewsTimeline.astro';
import ProjectEmptyState from '../components/academic/ProjectEmptyState.astro';
import { academicNews, academicProfile, academicProjects } from '../data/academic';
import { site } from '../data/site';

const role = `${academicProfile.title} at ${academicProfile.institute}`;
---

<SiteLayout title={site.title} description={site.description}>
  <section class="academic-intro" aria-labelledby="page-title">
    <h1 id="page-title">Jiaxin Li</h1>
    <p class="role-line">{role}</p>
    <p class="academic-bio">{academicProfile.summary}</p>
    <div class="contact-links" aria-label="Academic links">
      <a href="mailto:ljx2986519980@gmail.com">Email</a>
      <a href="https://github.com/egoista0326">GitHub</a>
    </div>
  </section>

  <AcademicSection title="News">
    <NewsTimeline items={academicNews} />
  </AcademicSection>

  <AcademicSection title="Projects">
    <ProjectEmptyState empty={academicProjects.empty} />
  </AcademicSection>
</SiteLayout>
