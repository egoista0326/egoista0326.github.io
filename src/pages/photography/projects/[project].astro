---
import { getCollection } from 'astro:content';
import SiteLayout from '../../../layouts/SiteLayout.astro';
import PhotoGrid from '../../../components/photography/PhotoGrid.astro';
import {
  photographyProjects,
  type PhotographyProject
} from '../../../data/photography';
import {
  getPhotoSlug,
  getPhotosBySlugs,
  getProjectPhotoHref,
  type PhotoEntry
} from '../../../lib/photography';

interface Props {
  project: PhotographyProject;
  photos: PhotoEntry[];
}

export async function getStaticPaths() {
  const photos = await getCollection('photos');

  return photographyProjects.map((project) => ({
    params: { project: project.slug },
    props: {
      project,
      photos: getPhotosBySlugs(photos, project.photoSlugs)
    }
  }));
}

const { project, photos } = Astro.props;
const projectPhotoHrefs = Object.fromEntries(
  photos.map((photo) => [getPhotoSlug(photo), getProjectPhotoHref(project.slug, photo)])
);
---

<SiteLayout title={`${project.title} | Photography`} description={project.summary}>
  <section class="photography-section gallery-heading" aria-labelledby="project-title">
    <p>
      <a class="photo-back-link" href="/photography/">
        <span data-lang-inline="en">Back to Photography</span>
        <span data-lang-inline="zh">返回摄影</span>
      </a>
    </p>
    <p class="metadata-kicker">
      <span data-lang-inline="en">Photography Project</span>
      <span data-lang-inline="zh">摄影项目</span>
    </p>
    <h1 id="project-title">
      <span data-lang-inline="en">{project.title}</span>
      <span data-lang-inline="zh">{project.titleZh}</span>
    </h1>
    <dl class="project-detail-meta">
      <div>
        <dt>
          <span data-lang-inline="en">Start date</span>
          <span data-lang-inline="zh">开始时间</span>
        </dt>
        <dd>{project.startDate}</dd>
      </div>
    </dl>
    <p class="section-copy project-description">
      <span data-lang-inline="en">{project.description}</span>
      <span data-lang-inline="zh">{project.descriptionZh}</span>
    </p>
  </section>

  <section class="photography-section" aria-label={`${project.title} photographs`}>
    <PhotoGrid
      photos={photos}
      photoHrefs={projectPhotoHrefs}
      emptyMessage="No photographs have been added to this project yet."
    />
  </section>
</SiteLayout>
