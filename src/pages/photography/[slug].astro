---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import PhotoDetailView from '../../components/photography/PhotoDetailView.astro';
import { photographySelectedWorkSlugs } from '../../data/photography';
import {
  getAdjacentPhotosInOrder,
  getPhotoAlt,
  getPhotoHref,
  getPhotoSlug,
  getPhotosBySlugs,
  isVisibleTitle,
  sortPhotosForDisplay,
  type PhotoEntry
} from '../../lib/photography';

interface Props {
  photo: PhotoEntry;
  previous?: PhotoEntry;
  next?: PhotoEntry;
}

export async function getStaticPaths() {
  const photos = sortPhotosForDisplay(await getCollection('photos'));
  const selectedPhotos = getPhotosBySlugs(photos, photographySelectedWorkSlugs);

  return photos.map((photo) => {
    const isSelectedWork = selectedPhotos.some((selectedPhoto) => getPhotoSlug(selectedPhoto) === getPhotoSlug(photo));
    const adjacentPhotos = isSelectedWork
      ? getAdjacentPhotosInOrder(selectedPhotos, getPhotoSlug(photo))
      : { previous: undefined, next: undefined };

    return {
      params: { slug: getPhotoSlug(photo) },
      props: {
        photo,
        previous: adjacentPhotos.previous,
        next: adjacentPhotos.next
      }
    };
  });
}

const { photo, previous, next } = Astro.props;
const pageTitle = isVisibleTitle(photo.data.title) ? `${photo.data.title} | Photography` : 'Photography';
const previousHref = previous ? getPhotoHref(previous) : undefined;
const nextHref = next ? getPhotoHref(next) : undefined;
---

<SiteLayout title={pageTitle} description={getPhotoAlt(photo)}>
  <PhotoDetailView
    photo={photo}
    previous={previous}
    previousHref={previousHref}
    next={next}
    nextHref={nextHref}
  />
</SiteLayout>
