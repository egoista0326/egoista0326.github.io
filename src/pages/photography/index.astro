---
import { getCollection } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { photographyProfile } from '../../data/photography';
import { photographyCategories } from '../../data/photographyVocab';
import CategoryEntry from '../../components/photography/CategoryEntry.astro';
import PhotoGrid from '../../components/photography/PhotoGrid.astro';
import {
  getCategoryHref,
  getPhotosByCategory,
  sortPhotosForDisplay
} from '../../lib/photography';

const profile = photographyProfile;
const photos = sortPhotosForDisplay(await getCollection('photos'));
const featuredPhotos = photos.filter((photo) => photo.data.featured);
const categoryEntries = photographyCategories.map((category) => {
  const categoryPhotos = getPhotosByCategory(photos, category.slug);

  return {
    category,
    photos: categoryPhotos,
    cover: categoryPhotos[0]
  };
});
---

<SiteLayout title="Photography" description={profile.intro}>
  <section class="photography-intro" aria-labelledby="page-title">
    <h1 id="page-title">{profile.title}</h1>
    <p>{profile.intro}</p>
    <div class="photography-contact" aria-label="Photography contact">
      <a href={`mailto:${profile.email}`}>{profile.email}</a>
      <a href={profile.instagram.url} target="_blank" rel="noreferrer">
        {profile.instagram.label}
      </a>
      <button class="rednote-trigger" type="button" data-rednote-open aria-label="Show Rednote Card">
        {profile.rednote.label}
      </button>
    </div>
  </section>

  <section class="photography-section" aria-labelledby="categories-title">
    <h2 id="categories-title">Categories</h2>
    <p class="section-copy">Browse photographs by subject before moving into selected works.</p>
    <div class="category-entry-list">
      {
        categoryEntries.map(({ category, photos: categoryPhotos, cover }) => (
          <CategoryEntry
            href={getCategoryHref(category.slug)}
            label={category.label}
            count={categoryPhotos.length}
            cover={cover}
          />
        ))
      }
    </div>
  </section>

  <section class="photography-section" aria-labelledby="selected-works-title">
    <h2 id="selected-works-title">Selected Works</h2>
    <PhotoGrid
      photos={featuredPhotos}
      emptyMessage="A small development set is being used to shape the browsing experience; the full selected import comes next."
    />
  </section>

  <section class="photography-section tag-entry" aria-labelledby="tag-entry-title">
    <h2 id="tag-entry-title">Tags</h2>
    <p class="section-copy">Browse by location, camera, lens, and weather.</p>
    <a class="text-link" href="/photography/tags/">Photography Tags</a>
  </section>

  <dialog class="rednote-dialog" data-rednote-dialog aria-labelledby="rednote-title">
    <div class="rednote-dialog-inner">
      <h2 id="rednote-title">{profile.rednote.title}</h2>
      <p class="muted">{profile.rednote.displayName} | Rednote ID {profile.rednote.id}</p>
      <img
        class="rednote-card"
        src={profile.rednote.cardImage}
        alt={profile.rednote.alt}
        loading="lazy"
      />
      <form method="dialog">
        <button class="dialog-close" type="submit" data-rednote-close>
          {profile.rednote.closeLabel}
        </button>
      </form>
    </div>
  </dialog>

  <script>
    const openButton = document.querySelector('[data-rednote-open]');
    const dialog = document.querySelector('[data-rednote-dialog]');

    if (openButton instanceof HTMLButtonElement && dialog instanceof HTMLDialogElement) {
      openButton.addEventListener('click', () => {
        dialog.showModal();
      });

      dialog.addEventListener('click', (event) => {
        if (event.target === dialog) {
          dialog.close();
        }
      });

      dialog.addEventListener('close', () => {
        openButton.focus();
      });
    }
  </script>
</SiteLayout>
