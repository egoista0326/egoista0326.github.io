---
import type { CategoryCover } from '../../data/photographyCategoryCovers';

interface Props {
  href: string;
  label: string;
  count?: number;
  cover?: CategoryCover;
}

const { href, label, count, cover } = Astro.props;
const countLabel =
  typeof count === 'number' ? `${count} photograph${count === 1 ? '' : 's'}` : '';
---

<a class="category-entry" href={href}>
  {
    cover ? (
      <span class="category-entry-image-frame">
        <img
          class="category-entry-image"
          src={cover.image}
          alt={cover.alt}
          width={cover.width}
          height={cover.height}
          loading="lazy"
          style={cover.objectPosition ? `object-position: ${cover.objectPosition}` : undefined}
        />
      </span>
    ) : null
  }
  <span class="category-entry-copy">
    <span class="category-entry-label">{label}</span>
    {countLabel ? <span class="category-entry-count">{countLabel}</span> : null}
  </span>
</a>
