---
import { getPhotoDisplayMeta, getPhotoHref, type PhotoEntry } from '../../lib/photography';

interface Props {
  previous?: PhotoEntry;
  previousHref?: string;
  next?: PhotoEntry;
  nextHref?: string;
}

const { previous, previousHref, next, nextHref } = Astro.props;
const getNavLabel = (photo: PhotoEntry) => {
  const meta = getPhotoDisplayMeta(photo);

  return meta.title || [meta.category, meta.location].filter(Boolean).join(', ');
};
---

{
  previous || next ? (
    <nav class="photo-nav" aria-label="Photo navigation">
      {previous ? (
        <a
          class="photo-nav-link"
          href={previousHref ?? getPhotoHref(previous)}
          aria-label={`Previous: ${getNavLabel(previous)}`}
        >
          <span>Previous</span>
        </a>
      ) : null}
      {next ? (
        <a
          class="photo-nav-link photo-nav-next"
          href={nextHref ?? getPhotoHref(next)}
          aria-label={`Next: ${getNavLabel(next)}`}
        >
          <span>Next</span>
        </a>
      ) : null}
    </nav>
  ) : null
}
