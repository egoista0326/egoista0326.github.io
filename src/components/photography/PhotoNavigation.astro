---
import { getPhotoDisplayMeta, getPhotoHref, type PhotoEntry } from '../../lib/photography';

interface Props {
  previous?: PhotoEntry;
  next?: PhotoEntry;
}

const { previous, next } = Astro.props;
const getNavLabel = (photo: PhotoEntry) => {
  const meta = getPhotoDisplayMeta(photo);

  return meta.title || [meta.category, meta.location].filter(Boolean).join(', ');
};
---

{
  previous || next ? (
    <nav class="photo-nav" aria-label="Photo navigation">
      {previous ? (
        <a
          class="photo-nav-link"
          href={getPhotoHref(previous)}
          aria-label={`Previous selected work: ${getNavLabel(previous)}`}
        >
          <span>Previous selected work</span>
        </a>
      ) : null}
      {next ? (
        <a
          class="photo-nav-link photo-nav-next"
          href={getPhotoHref(next)}
          aria-label={`Next selected work: ${getNavLabel(next)}`}
        >
          <span>Next selected work</span>
        </a>
      ) : null}
    </nav>
  ) : null
}
